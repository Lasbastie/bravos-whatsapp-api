# Bravos WhatsApp API — arquivo de configuração
# Copie pra .env e ajuste os valores

# --- Obrigatórios ---

# Token aleatório pra autenticar chamadas da API REST.
# Gere com: openssl rand -hex 32
API_TOKEN=troque-por-algo-aleatorio-forte

# --- Opcionais ---

# Porta HTTP do servidor (default: 8095)
PORT=8095

# Identificador único desta instância (usado como nome da pasta LocalAuth
# e no banco). Se você rodar MAIS DE UM worker na mesma VPS, dê um CLIENT_ID
# diferente pra cada um.
CLIENT_ID=bravos-worker

# Caminho do SQLite (default: ./data/whatsapp.db)
DB_PATH=./data/whatsapp.db

# Nível de log (debug | info | warn | error). Default: info
LOG_LEVEL=info
